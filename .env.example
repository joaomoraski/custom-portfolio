# Database
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio"

# If DATABASE_URL uses a pooler (Neon, Supabase, Prisma Data Proxy, etc.), set the
# direct (non-pooled) URL for Prisma CLI — migrate deploy needs advisory locks.
# On Vercel, add DIRECT_URL in project env vars with the same value the host labels
# "direct" / "unpooled" / port 5432 (not the pooler port).
# DIRECT_URL="postgresql://..."

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Admin credentials (used by seed script to create the single admin user)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-to-something-strong"

# SMTP for contact form email notifications (OPTIONAL)
# If not set, contact messages are stored in DB only — no email will be sent.
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# CONTACT_EMAIL="joaomoraskilunkes@gmail.com"
